{
  "extends": "@slzr/expensr-shared/tsconfig.vue.json",
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue",

    "src/**/*.ts", // TODO: check if needed

    // Nuxt UI
    "auto-imports.d.ts",
    "components.d.ts"
  ],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],

      "#build/ui/*": [
        "./node_modules/.nuxt-ui/ui/*"
      ]
    },
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo"
  }
}
