{
	"name": "@slzr/expensr-web",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vue-tsc --build && vite build",
		"preview": "pnpm run build && wrangler dev",
		"type-check": "vue-tsc --build",
		"deploy:cf": "pnpm run build && wrangler deploy",
		"typegen:cf": "wrangler types --env-interface CloudflareBindings",
		"db:migrate": "wrangler d1 migrations apply expensr-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply expensr-db --remote"
	},
	"dependencies": {
		"@fontsource-variable/bricolage-grotesque": "^5.2.10",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@fontsource-variable/manrope": "^5.2.8",
		"@nuxt/ui": "^4.5.1",
		"@slzr/expensr-api": "workspace:*",
		"tailwindcss": "^4.2.1",
		"vue": "^3.5.29",
		"vue-router": "^5.0.3"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.26.0",
		"@cloudflare/workers-types": "^4.20260307.1",
		"@slzr/expensr-shared": "workspace:*",
		"@types/node": "catalog:",
		"@vitejs/plugin-vue": "^6.0.4",
		"typescript": "catalog:",
		"vite": "^7.3.1",
		"vite-plugin-vue-devtools": "^8.0.6",
		"vue-tsc": "^3.2.5",
		"wrangler": "catalog:"
	},
	"engines": {
		"node": "^20.19.0 || >=22.12.0"
	}
}
